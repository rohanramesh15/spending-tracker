# Frontend env — safe values only (anon key is public). Copy to .env for local dev.
# Production values are set in the Cloudflare Pages dashboard, not committed.

# Lambda Function URL of the backend (leave blank in local dev; Vite proxies /api).
VITE_API_BASE_URL=

# Supabase project — the publishable key is designed to be public; RLS protects the data.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Google Maps JS key for the cheaper-store finder map (Phase 5). Restrict it by HTTP
# referrer in Google Cloud. Leave blank until Phase 5 — the finder falls back to a list.
VITE_GOOGLE_MAPS_API_KEY=
