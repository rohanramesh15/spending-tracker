# Backend env for LOCAL DEV ONLY. Never commit real values; prod reads from SSM.
# Copy to .env and fill in.

# Supabase Postgres via the Supavisor transaction pooler (port 6543), NOT direct 5432.
# Format: postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/postgres

# Supabase JWT verification — set ONE of these:
#   HS256 legacy shared secret (Project Settings → API → JWT secret), or
#   the project JWKS URL for asymmetric keys: https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUD=authenticated

# Receipt extraction (Phase 2). Get a key at https://aistudio.google.com/apikey.
# Leave blank to use the deterministic mock extractor (scan/confirm flow still works).
# PRIVACY: the Gemini FREE tier may use your inputs to improve Google's products — i.e.
# your receipt images. Fine for prototyping; switch to a paid/billed key before feeding
# real financial data (CLAUDE.md guardrail). The code path is identical for either tier.
# In prod this comes from SSM SecureString /<prefix>/gemini-api-key, not this file.
GEMINI_API_KEY=
# Optional model override (defaults to gemini-2.5-flash, the locked choice — plan §8).
GEMINI_MODEL=gemini-2.5-flash

# Comma-separated frontend origins allowed by CORS.
CORS_ALLOW_ORIGINS=["http://localhost:5173"]

# Local-only: skip JWT verification for manual curl testing. NEVER set true in prod.
AUTH_DEV_BYPASS=false
